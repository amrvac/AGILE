
 &filelist
   base_filename = 'output/ring_tc-ffhd'
   saveprim      = T
   autoconvert   = T
   convert_type  = 'vtuBCCmpi'
   nwauxio       = 1
 /

 &savelist
   itsave(1,1)   = 0
   itsave(1,2)   = 0
   ditsave_log   = 40
   dtsave_dat    = 10.0d0
 /

 &stoplist
   time_max = 50.0d0
 /

 &methodlist
   time_stepper             = 'threestep'
   flux_scheme              = 20*'tvdlf'
   limiter                  = 20*'minmod'
   phys                     = 'ffhd'
   flux_adaptive_diffusion  = .true.
   flux_ad_min              = 0.2d0
   flux_ad_scale            = 0.5d0
 /

 &boundlist
   typeboundary_min1 = 4*'periodic'
   typeboundary_max1 = 4*'periodic'
   typeboundary_min2 = 4*'periodic'
   typeboundary_max2 = 4*'periodic'
   typeboundary_min3 = 4*'periodic'
   typeboundary_max3 = 4*'periodic'
 /

 &meshlist
   max_blocks       = 25
   refine_max_level = 1
   block_nx1        = 40
   block_nx2        = 40
   block_nx3        = 4
   domain_nx1       = 200
   domain_nx2       = 200
   domain_nx3       = 4
   xprobmin1        = -1.0d0
   xprobmax1        =  1.0d0
   xprobmin2        = -1.0d0
   xprobmax2        =  1.0d0
   xprobmin3        = -0.02d0
   xprobmax3        =  0.02d0
 /

 &paramlist
   slowsteps   = 10
   courantpar  = 0.7d0
   typecourant = 'maxsum'
 /

 &ffhd_list
   ffhd_gamma                         = 1.6666667d0
   ffhd_hyperbolic_thermal_conduction = .true.
   ffhd_energy_only                   = .true.
 /
