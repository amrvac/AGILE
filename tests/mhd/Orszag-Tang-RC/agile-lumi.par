
 &filelist
   base_filename    = 'output/ot3d'
   autoconvert      = F
   saveprim         = T
   typefilelog      = 'special'
 /

 &savelist
   itsave(1,1)      = 0
   itsave(1,2)      = 0
   ditsave_log      = 100
   dtsave_dat       = 0.5
   dtsave_slice     = 0.1
   nslices          = 3
   slicedir(1)      = 1
   slicecoord(1)    = 0.5d0
   slicedir(2)      = 2
   slicecoord(2)    = 0.5d0
   slicedir(3)      = 3
   slicecoord(3)    = 0.5d0
 /

 &stoplist
   time_max = 2.5
 /

 &methodlist
   time_stepper    = 'threestep'
   flux_scheme     = 20*'tvdlf'
   limiter         = 20*'vanleer'
   phys            = 'mhd'
 /

 &boundlist
   typeboundary_min1 = 8*'periodic'
   typeboundary_max1 = 8*'periodic'
   typeboundary_min2 = 8*'periodic'
   typeboundary_max2 = 8*'periodic'
   typeboundary_min3 = 8*'periodic'
   typeboundary_max3 = 8*'periodic'
 /

 &meshlist
   max_blocks         = 100000
   refine_criterion   = 3
   refine_max_level   = 4
   refine_threshold   = 20*0.4d0
   w_refine_weight(1) = 0.5d0    ! rho
   w_refine_weight(5) = 0.5d0    ! energy (pressure proxy)
   block_nx1          = 16
   block_nx2          = 16
   block_nx3          = 16
   domain_nx1         = 128
   domain_nx2         = 128
   domain_nx3         = 128
   xprobmin1       = 0.0d0
   xprobmax1       = 1.0d0
   xprobmin2       = 0.0d0
   xprobmax2       = 1.0d0
   xprobmin3       = 0.0d0
   xprobmax3       = 1.0d0
 /

 &paramlist
   slowsteps        = 10
   courantpar       = 0.8d0
   typecourant      = 'maxsum'
 /

 &mhd_list
   mhd_radiative_cooling = .true.
   mhd_source_usr        = .true.
 /

 &rc_list
   ncool      = 4000
   coolcurve  = 'Colgan_DM'
   Tfix       = .true.
   tlow       = 1.0d-4
 /

 &usr_list
   mach0  = 1.0d0
   T0     = 0.25d0
   pbeta0 = 3.0d0
   rho0   = 4.0d0
 /
