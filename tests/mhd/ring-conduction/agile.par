
 &filelist
   base_filename = 'output/ring_tc-vtwo-noadaptiveflux'
   saveprim      = T
   autoconvert   = T
   convert_type  = 'vtuBCCmpi'
   nwauxio       = 1
 /

 &savelist
   itsave(1,1)   = 0
   itsave(1,2)   = 0
   ditsave_log   = 40
   dtsave_dat    = 50.0d0
   ! dtsave_slice  = 10.0d0
   ! nslices       = 1
   ! slicedir(1)   = 3
   ! slicecoord(1) = 0.0d0
 /

 &stoplist
   time_max = 400.0d0
 /

 &methodlist
   time_stepper             = 'threestep'
   flux_scheme              = 20*'tvdlf'
   limiter                  = 20*'mc'
   phys                     = 'mhd'
   flux_adaptive_diffusion  = .false.
   flux_ad_min              = 0.2d0
   flux_ad_scale            = 0.5d0
 /

 &boundlist
   typeboundary_min1 = 8*'periodic'
   typeboundary_max1 = 8*'periodic'
   typeboundary_min2 = 8*'periodic'
   typeboundary_max2 = 8*'periodic'
   typeboundary_min3 = 8*'periodic'
   typeboundary_max3 = 8*'periodic'
 /

 &meshlist
   max_blocks       = 100
   refine_max_level = 1
   block_nx1        = 20
   block_nx2        = 20
   block_nx3        = 4
   domain_nx1       = 200
   domain_nx2       = 200
   domain_nx3       = 4
   xprobmin1        = -1.0d0
   xprobmax1        =  1.0d0
   xprobmin2        = -1.0d0
   xprobmax2        =  1.0d0
   xprobmin3        = -0.02d0
   xprobmax3        =  0.02d0
 /

 &paramlist
   slowsteps   = 10
   courantpar  = 0.7d0
   typecourant = 'maxsum'
 /

 &mhd_list
   mhd_gamma                                    = 1.6666667d0
   mhd_hyperbolic_thermal_conduction = .true.
   tc_kappa_par                      = 0.01d0
   mhd_energy_only = .true.
 /
