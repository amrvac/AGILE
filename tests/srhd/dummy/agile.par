
 &filelist
   base_filename    = 'output/3d'
   autoconvert      = T
 /

 &savelist
   itsave(1,1)      = 0
   itsave(1,2)      = 0
   ditsave_log      = 1
   ditsave_dat      = 10
 /

 &stoplist
   it_max           = 50
 /

 &methodlist
   time_stepper    = 'threestep'
   flux_scheme     = 20*'tvdlf'
   limiter         = 20*'vanleer'
   small_values_method = 'ignore'
   phys                = 'srhd'
 /

 &boundlist
   typeboundary_min1 = 5*'periodic'
   typeboundary_max1 = 5*'periodic'
   typeboundary_min2 = 5*'periodic'
   typeboundary_max2 = 5*'periodic'
   typeboundary_min3 = 5*'periodic'
   typeboundary_max3 = 5*'periodic'
 /

 &meshlist
   max_blocks         = 4096
   refine_max_level   = 1
   block_nx1          = 10
   block_nx2          = 10
   block_nx3          = 10
   domain_nx1         = 100
   domain_nx2         = 100
   domain_nx3         = 100
   xprobmin1       = 0.0d0
   xprobmax1       = 1.0d0
   xprobmin2       = 0.0d0
   xprobmax2       = 1.0d0
   xprobmin3       = 0.0d0
   xprobmax3       = 1.0d0
   iprob=1
 /

 &paramlist
   slowsteps        = 10
   courantpar       = 0.7d0
   typecourant      = 'maxsum'
 /
 
&srhd_list
   srhd_gamma=1.666667d0
   srhd_eos=.false.
   He_abundance=0.0d0
   srhd_source_usr=.false.
   srhd_n_tracer=0
/
