
 &filelist
   base_filename    = 'output/RelJet3d_lfac20_'
   autoconvert      = F
   nwauxio=1
   saveprim=T
 /

 &savelist
   itsave(1,1)      = 0
   itsave(1,2)      = 0
   itsave(1,3)      = 0
   dtsave_log       = 0.5d0
   dtsave_dat       = 1.0d0
   dtsave_slice     = 0.1d0
   nslices          = 3
   slicedir(1)      = 1
   slicecoord(1)    = 0.0d0
   slicedir(2)      = 2
   slicecoord(2)    = 0.0d0
   slicedir(3)      = 3
   slicecoord(3)    = 40.0d0
 /

 &stoplist
   time_max           = 200.0d0
 /

 &methodlist
   time_stepper    = 'threestep'
   flux_scheme     = 20*'tvdlf'
   limiter         = 20*'vanleer'
   small_values_method = 'ignore'
   phys                = 'srhd'
 /

 &boundlist
   specialboundary   = T
   typeboundary_min1 = 5*'cont'
   typeboundary_max1 = 5*'cont'
   typeboundary_min2 = 5*'cont'
   typeboundary_max2 = 5*'cont'
   typeboundary_min3 = 5*'special'
   typeboundary_max3 = 5*'cont'
 /

 &meshlist
   refine_usr=.true.
   refine_criterion=3
   max_blocks         = 4096
   refine_max_level   = 2
   block_nx1          = 20
   block_nx2          = 20
   block_nx3          = 20
   domain_nx1         = 240
   domain_nx2         = 240
   domain_nx3         = 480
   xprobmin1       = -20.0d0
   xprobmax1       = 20.0d0
   xprobmin2       = -20.0d0
   xprobmax2       = 20.0d0
   xprobmin3       = 0.0d0
   xprobmax3       = 80.0d0
 /

 &paramlist
   slowsteps        = 1000
   courantpar       = 0.4d0
   typecourant      = 'maxsum'
 /
 
&srhd_list
   srhd_gamma=1.666667d0
   srhd_eos=.true.
   He_abundance=0.1d0
   srhd_source_usr=.false.
   srhd_n_tracer=1
/

&usr_list
    rjet= 1.0d0
    zjet=0.25d0
    rhob=1.0d0
    etarho=1.0d-5
    pb=7.64d-6
    zetap=1.0d0
    lfacjet=20.0d0
/
