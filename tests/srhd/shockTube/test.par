
 &filelist
   base_filename    = 'test'
   typefilelog      = 'regression_test'
 /

 &savelist
   dtsave_log       = 1.0d10
   dtsave_slice     = 1.0d10
 /

 &stoplist
   time_max         = 0.4d0
 /

 &methodlist
   time_stepper    = 'threestep'
   flux_scheme     = 20*'tvdlf'
   limiter         = 20*'vanleer'
   phys            = 'srhd'
 /

 &boundlist
   typeboundary_min1 = 5*'cont'
   typeboundary_max1 = 5*'cont'
   typeboundary_min2 = 5*'periodic'
   typeboundary_max2 = 5*'periodic'
   typeboundary_min3 = 5*'periodic'
   typeboundary_max3 = 5*'periodic'
 /

 &meshlist
   max_blocks         = 128
   refine_max_level   = 2
   block_nx1          = 10
   block_nx2          = 10
   block_nx3          = 10
   domain_nx1         = 100
   domain_nx2         = 10
   domain_nx3         = 10
   xprobmin1       = 0.0d0
   xprobmax1       = 1.0d0
   xprobmin2       = 0.0d0
   xprobmax2       = 0.1d0
   xprobmin3       = 0.0d0
   xprobmax3       = 0.1d0
   iprob=1
 /

 &paramlist
   slowsteps        = 10
   courantpar       = 0.7d0
   typecourant      = 'maxsum'
 /
 
&srhd_list
   srhd_gamma=1.666667d0
   srhd_eos=.false.
   He_abundance=0.0d0
/
