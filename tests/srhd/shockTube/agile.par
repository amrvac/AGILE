
 &filelist
   base_filename    = 'output/shockTube'
   autoconvert      = T
   saveprim         = T
 /

 &savelist
   itsave(1,1)      = 0
   itsave(1,2)      = 0
   itsave(1,3)      = 0
   ditsave_log      = 10
   dtsave_slice     = 0.1d0
   nslices          = 1
   slicecoord(1)    = 0.05d0
   slicedir(1)      = 3
 /

 &stoplist
   time_max         = 0.4d0
 /

 &methodlist
   time_stepper    = 'threestep'
   flux_scheme     = 20*'tvdlf'
   limiter         = 20*'vanleer'
   phys            = 'srhd'
 /

 &boundlist
   typeboundary_min1 = 5*'cont'
   typeboundary_max1 = 5*'cont'
   typeboundary_min2 = 5*'periodic'
   typeboundary_max2 = 5*'periodic'
   typeboundary_min3 = 5*'periodic'
   typeboundary_max3 = 5*'periodic'
 /

 &meshlist
   max_blocks         = 2048
   refine_max_level   = 4
   block_nx1          = 10
   block_nx2          = 10
   block_nx3          = 10
   domain_nx1         = 100
   domain_nx2         = 10
   domain_nx3         = 10
   xprobmin1       = 0.0d0
   xprobmax1       = 1.0d0
   xprobmin2       = 0.0d0
   xprobmax2       = 0.1d0
   xprobmin3       = 0.0d0
   xprobmax3       = 0.1d0
   iprob=1
 /

 &paramlist
   slowsteps        = 10
   courantpar       = 0.7d0
   typecourant      = 'maxsum'
 /
 
&srhd_list
   srhd_gamma=1.666667d0
   srhd_eos=.false.
   He_abundance=0.0d0
/
